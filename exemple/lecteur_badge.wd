cURLDLL est une chaîne = fRepExe() + "\SWHidApi.dll"
hDLL			est un entier système
eNumeroLecteur	est un entier

hDLL = ChargeDLL(cURLDLL)
si hDLL = 0 alors
	Trace(ErreurInfo())
sinon
	//Trace("DLL chargée !")
	//DéchargeDLL(hInst)
fin


// Résumé : <indiquez ici ce que fait la procédure>
// Syntaxe :
//[ <Résultat> = ] DécoderVersionDepuisOctet (<nOctet> est entier sans signe sur 4 octets)
//
// Paramètres :
//	nOctet (entier sans signe sur 4 octets) : <indiquez ici le rôle de nOctet>
// Valeur de retour :
// 	multi-valeur : <indiquez ici le rôle de la valeur de retour>
//
// Exemple :
// <Indiquez ici un exemple d'utilisation>
//
procédure DécoderVersionDepuisOctet(nOctet est un entier sans signe )
nMajeure	est un entier	= bitDécaleDroite(nOctet,4)	// Bits 7-4
nMineure	est un entier	= ETBinaire(nOctet,0x0F)	// Bits 3-0
renvoyer (nMajeure, nMineure)
// Résumé : <indiquez ici ce que fait la procédure>
// Syntaxe :
//[ <Résultat> = ] Addresse_lecteur ()
//
// Paramètres :
//	Aucun
// Valeur de retour :
// 	booléen : <indiquez ici le rôle de la valeur de retour>
//
// Exemple :
// <Indiquez ici un exemple d'utilisation>
//
procédure Addresse_lecteur()
buffAPI est un Buffer sur 256
bRetourAPI est un booléen

bRetourAPI = API("SWHidApi", "SWHid_GetUsbInfo", 0, &buffAPI)

si bRetourAPI alors
	Trace("Adresse USB : " + buffAPI)
	retour Vrai
sinon
	Trace("Erreur de récupération de l'adresse USB")
	retour Faux
fin
