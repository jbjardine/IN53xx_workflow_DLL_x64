// Résumé : <indiquez ici ce que fait la procédure>
// Syntaxe :
// Informations_lecteur ()
//
// Paramètres :
//	Aucun
// Valeur de retour :
// 	Aucune
//
// Exemple :
// <Indiquez ici un exemple d'utilisation>
//
procédure Informations_lecteur()
buffAPI est un Buffer sur 64
bRetourAPI est un booléen
eMineurSoftVer est un entier
eMajeureSoftVer est un entier
eMineurHardVer	est un entier
eMajeureHardVer	est un entier
cDeviceSN est une chaîne

/******** Func: GetDeviceInfo. 9Bytes**********/
//  Param: bDevAdr: 0xFF
//         pucSystemInfo: SysInfo  9Bytes 1:SoftVer 2:HardVer 3-9:DeviceSN
//  Return: Success return 1, failed return 0
/*********************************************************/
bRetourAPI = API("SWHidApi","SWHid_GetDeviceSystemInfo", 0xFF, &buffAPI)

si bRetourAPI alors
	eSoftVer est un entier sans signe = BufferVersEntier(buffAPI,0,1)
	eHardVer est un entier sans signe = BufferVersEntier(buffAPI,1,1)
	(eMajeureSoftVer, eMineurSoftVer) = DécoderVersionDepuisOctet(eSoftVer)
	(eMajeureHardVer, eMineurHardVer) = DécoderVersionDepuisOctet(eHardVer)

	pour i = 3 à 9
		eDeviceSN est un entier sans signe = BufferVersEntier(buffAPI,i-1,1)
		cDeviceSN += NumériqueVersChaîne(eDeviceSN, "02x")
	fin
	cDeviceSN = Majuscule(cDeviceSN)

	Trace("Software : v" + eMajeureSoftVer + "." + eMineurSoftVer + " ; Hardware : v" +  eMajeureHardVer + "." +  eMineurHardVer + " ; S/N : " + cDeviceSN)
sinon
	Trace("Erreur de récupération des informations du lecteur")

fin
