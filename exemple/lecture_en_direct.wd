// Valeur de retour :
// 	Aucune
//
// Exemple :
// <Indiquez ici un exemple d'utilisation>
//
procédure Nettoyage_badges()
HSupprimeTout(Bagdes_en_cours_lecture)
HRéindexe(Bagdes_en_cours_lecture)
// Résumé : <indiquez ici ce que fait la procédure>
// Syntaxe :
//Mise_a_jour_Badge_Direct (<cUUID> est chaîne)
//
// Paramètres :
//	cUUID (chaîne ANSI) : <indiquez ici le rôle de cUUID>
// Valeur de retour :
// 	Aucune
//
// Exemple :
// <Indiquez ici un exemple d'utilisation>
//
procédure Mise_a_jour_Badge_Direct(cUUID est une chaîne)

REQ_Badge_Attribue.ParamUUID_badge = cUUID
bRésultat est un booléen = HExécuteRequête(REQ_Badge_Attribue)
si REQ_Badge_Attribue.Existe alors
	REQ_Badge_existe_Lecture_en_cours.ParamUUID_badge = cUUID
	bRésultat2 est un booléen = HExécuteRequête(REQ_Badge_existe_Lecture_en_cours)
	si REQ_Badge_existe_Lecture_en_cours.Existe = 1 alors
		REQ_MiseAJour_Horodatage_Lecture_en_cours.ParamUUID_badge = cUUID
		HExécuteRequête(REQ_MiseAJour_Horodatage_Lecture_en_cours,hVérifieDoublon)
		//trace("MAJ ID UUID : " + cUUID)
	sinon
		REQ_Inserer_Badge_Lecture_en_cours.ParamUUID_badge = cUUID
		HExécuteRequête(REQ_Inserer_Badge_Lecture_en_cours,hVérifieDoublon)
		//Trace("Insertion ID UUID : " + cUUID)
	fin
fin
