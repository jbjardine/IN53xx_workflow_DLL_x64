//
procédure Lancement_boucle_en_direct()
si LecteurBadge.Lecteur_présent alors
//si FI_ListePersonnelEnCours.bLecteurConnecte alors
	//LecteurBadge.Addresse_lecteur()
	LecteurBadge.Connexion_lecteur
	LecteurBadge.Nettoyage_Buffer
	//Lecteurbadge.Informations_lecteur()
	BoucleLectureEnDirect()
fin
