procédure ArretBoucleEnDirect()
FinAutomatismeProcédure(BoucleLectureEnDirect)
// Résumé : <indiquez ici ce que fait la procédure>
// Syntaxe :
//Badge_selon_delai ( [<eEcartTempsLecture_secondes> est entier])
//
// Paramètres :
//	eEcartTempsLecture_secondes (entier - valeur par défaut=10) : <indiquez ici le rôle de eEcartTempsLecture_secondes>
// Valeur de retour :
// 	Aucune
//
// Exemple :
// <Indiquez ici un exemple d'utilisation>
//
procédure Badge_selon_delai(eEcartTempsLecture_secondes est un entier = 10)
// Par défault, délai de 10s, paramétrable

REQ_Badge_Lecture_en_cours_Horodatage.ParamDateHeure1 = eEcartTempsLecture_secondes
bRésultat est un booléen = HExécuteRequête(REQ_Badge_Lecture_en_cours_Horodatage)

tUUID est un tableau de chaîne

si bRésultat alors
	pour chaque REQ_Badge_Lecture_en_cours_Horodatage
		TableauAjoute(tUUID, REQ_Badge_Lecture_en_cours_Horodatage.UUID_badge)
	fin
fin
renvoyer tUUID
// Résumé : <indiquez ici ce que fait la procédure>
